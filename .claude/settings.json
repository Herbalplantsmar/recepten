{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate_data.py\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python -m http.server:*)",
      "Bash(python -m json.tool:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)"
    ]
  }
}
